rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper Functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    function isAdmin() {
      return isSignedIn() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }

    // USERS COLLECTION
    match /users/{userId} {
      allow read: if true;
      allow create: if isOwner(userId);
      // Allow user to update their own profile, including upgrading status to 'Guide'
      // Ideally we'd validate the count here, but queries are expensive/limited in rules.
      // We trust the client to only set 'Guide' if verifiedCount >= 10, 
      // but strictly enforce that they can only modify their own doc.
      allow update: if isOwner(userId) || isAdmin();
    }
    
    // ENTRIES COLLECTION
    match /entries/{entryId} {
      allow read: if true;
      
      // CREATE: Standard contribution
      allow create: if isSignedIn() 
                    && request.resource.data.status == 'pending'
                    && request.resource.data.contributorId == request.auth.uid;
                    
      // UPDATE: Voting or Admin actions
      allow update: if isAdmin() || (
        isSignedIn() && 
        resource.data.status == 'pending' && (
          // Case 1: Positive Voting (Reviewer adds their ID to votes array)
          (
            request.resource.data.diff(resource.data).affectedKeys().hasOnly(['votes', 'vote_count', 'status', 'timestamp']) &&
            request.resource.data.vote_count == resource.data.vote_count + 1 &&
            request.resource.data.votes.hasAll(resource.data.votes) &&
            request.resource.data.votes.hasAny([request.auth.uid]) &&
            request.resource.data.votes.size() == resource.data.votes.size() + 1
          ) ||
          // Case 2: Negative Voting/Rejection (Reviewer adds their ID to rejections array)
          (
            request.resource.data.diff(resource.data).affectedKeys().hasOnly(['rejections', 'rejection_count', 'status', 'timestamp']) &&
            request.resource.data.rejection_count == resource.data.rejection_count + 1 &&
            request.resource.data.rejections.hasAll(resource.data.rejections) &&
            request.resource.data.rejections.hasAny([request.auth.uid]) &&
            request.resource.data.rejections.size() == resource.data.rejections.size() + 1
          ) ||
          // Case 3: Editing (Only if it's their own entry)
          resource.data.contributorId == request.auth.uid
        )
      );
      
      // DELETE: Admins only
      allow delete: if isAdmin();
    }

    // EDIT_PROPOSALS COLLECTION
    match /edit_proposals/{proposalId} {
      allow read: if isSignedIn();
      // Anyone signed in can create a proposal
      allow create: if isSignedIn() && request.resource.data.status == 'pending';

      // Voting: only allow incrementing votes_for or votes_against fields
      allow update: if isSignedIn() && (
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['votes_for', 'votes_against', 'updatedAt']) &&
        // Ensure increments are positive integers
        request.resource.data.votes_for >= resource.data.votes_for &&
        request.resource.data.votes_against >= resource.data.votes_against &&
        (request.resource.data.votes_for - resource.data.votes_for == 1 || request.resource.data.votes_against - resource.data.votes_against == 1)
      );

      // Admins can delete or modify status (accepted/rejected)
      allow delete, update: if isAdmin();
    }
  }
}
